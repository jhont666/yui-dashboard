generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  telegramId String    @id
  name       String
  airdrops   Json?     // Menyimpan array airdrop (bisa di-normalisasi nanti jika ingin lebih kompleks)
  otps       Otp[]
}

model Otp {
  id         String   @id @default(cuid())
  code       String   @unique
  telegramId String
  expiresAt  DateTime
  user       User     @relation(fields: [telegramId], references: [telegramId])
}